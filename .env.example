# === Gemini AI Configuration ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Proxy Configuration ===
# Residential proxy URL (e.g., from BrightData, Oxylabs, SmartProxy)
# Format: http://user:pass@host:port
PROXY_URL=

# === Scraper Configuration ===
# Options: amazon, jbhifi, kogan, phonebot
SCRAPER_TARGET=amazon

# === Mapping Configuration ===
# Options: MAPPING REFURBISHED, MAPPING BRAND NEW, MAPPING BRAND NEW Laptop, MAPPING BRAND NEW Lens dan Camera
MAPPING_CATEGORY=MAPPING BRAND NEW

# === Amazon Configuration ===
AMAZON_DOMAIN=amazon.com.au

# === JB Hi-Fi Configuration ===
JBHIFI_DOMAIN=www.jbhifi.com.au
 
# === Kogan Configuration ===
KOGAN_DOMAIN=www.kogan.com.au

# === Phonebot Configuration ===
PHONEBOT_DOMAIN=www.phonebot.com.au

# === Mobileciti Configuration ===
MOBILECITI_DOMAIN=www.mobileciti.com.au

# === BuyMobile Configuration ===
BUYMOBILE_DOMAIN=buymobile.com.au

# === Spectronic Configuration ===
SPECTRONIC_DOMAIN=spectronic.com.au

# === BestMobilePhone Configuration ===
BESTMOBILEPHONE_DOMAIN=bestmobilephone.com.au

# === Scorptec Configuration ===
SCORPTEC_DOMAIN=www.scorptec.com.au

# === Centre Com Configuration ===
CENTRECOM_DOMAIN=www.centrecom.com.au

# === Digidirect Configuration ===
DIGIDIRECT_DOMAIN=www.digidirect.com.au

# === Georges Configuration ===
GEORGES_DOMAIN=www.georges.com.au

# === Scraping Behavior ===
# Random delay range between requests (milliseconds)
REQUEST_DELAY_MIN_MS=3000
REQUEST_DELAY_MAX_MS=8000

# Max search results to analyze per product
MAX_SEARCH_RESULTS=5

# === File Paths ===
INPUT_CSV_PATH=input/products.csv
OUTPUT_DIR=output
